@article{smithEffectsTemperatureEmbryonic2015,
  title = {Effects of Temperature on Embryonic and Early Larval Growth and Development in the Rough-Skinned Newt ({{{\emph{Taricha}}}}{\emph{ Granulosa}})},
  author = {Smith, Geoffrey D. and Hopkins, Gareth R. and Mohammadi, Shabnam and M. Skinner, Heather and Hansen, Tyler and Brodie, Edmund D. and French, Susannah S.},
  year = 2015,
  month = jul,
  journal = {Journal of Thermal Biology},
  volume = {51},
  pages = {89--95},
  issn = {0306-4565},
  doi = {10.1016/j.jtherbio.2015.03.010},
  urldate = {2024-12-13},
  abstract = {We investigated the effects of temperature on the growth and development of embryonic and early larval stages of a western North American amphibian, the rough-skinned newt (Taricha granulosa). We assigned newt eggs to different temperatures (7, 14, or 21{$^\circ$}C); after hatching, we re-assigned the newt larvae into the three different temperatures. Over the course of three to four weeks, we measured total length and developmental stage of the larvae. Our results indicated a strong positive relationship over time between temperature and both length and developmental stage. Importantly, individuals assigned to cooler embryonic temperatures did not achieve the larval sizes of individuals from the warmer embryonic treatments, regardless of larval temperature. Our investigation of growth and development at different temperatures demonstrates carry-over effects and provides a more comprehensive understanding of how organisms respond to temperature changes during early development.},
  keywords = {Amphibian,Carry-over effects,Development,Egg,Growth,Larvae}
}

