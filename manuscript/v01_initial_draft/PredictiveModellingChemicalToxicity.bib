  title = {Energy Budgets for Tadpoles Approaching Metamorphosis},
  author = {Pfab, Ferdinand and DiRenzo, Graziella V. and Gershman, Ariel and Briggs, Cheryl J. and Nisbet, Roger M},
  year = 2020,
